# Application
APP_NAME="Farewell"
APP_ENV="development"                      # development | staging | production
APP_DEBUG=true
APP_BASE_URL="http://localhost:8000"
FRONTEND_URL="http://localhost:3000"

# Security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY="replace-with-a-64-char-random-hex-string"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8

# Separate secret for signing state parameters
STATE_HMAC_SECRET="replace-with-a-different-64-char-random-hex-string"

# Invitation-based authentication
INVITATION_TOKEN_EXPIRE_DAYS=30

# Admin login password hash
# Generate with: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))"
ADMIN_PASSWORD_HASH=""

# Database — PostgreSQL (Neon or local)
# Paste your Neon connection string as-is; the app normalises it automatically.
# Local example:  postgresql://localhost/farewell
# Neon example:   postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://localhost/farewell"
DATABASE_SSL=false                         # Set to true for Neon / remote PostgreSQL

# Cloudinary — https://cloudinary.com (free tier is sufficient)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Admin access — comma-separated list of emails that can log in to the admin portal
ADMIN_EMAILS=""

# CORS — defaults to FRONTEND_URL if not set.
# Override here only if you need to allow additional origins.
CORS_ALLOWED_ORIGINS=""

# File upload size limit (enforced before sending to Cloudinary)
MAX_UPLOAD_SIZE_MB=50

# Logging
LOG_LEVEL="INFO"                           # DEBUG | INFO | WARNING | ERROR
