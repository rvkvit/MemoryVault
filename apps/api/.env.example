# Application
APP_NAME="Farewell"
APP_ENV="development"                      # development | staging | production
APP_DEBUG=true
APP_BASE_URL="http://localhost:8000"
FRONTEND_URL="http://localhost:3000"

# Security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY="6a2c700ae16d1078cd1d0099b9f76f265b18c799485e7ea53d105e6c4ab27646"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8

# Separate secret for signing state parameters
STATE_HMAC_SECRET="71d6f5b0c62895913c3df9bab32927056dc3b700c6511ba44efb072e41d8dcf4"

# Invitation-based authentication
INVITATION_TOKEN_EXPIRE_DAYS=30

# Admin login password hash
# Generate with: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))"
ADMIN_PASSWORD_HASH="$2b$12$WI4qdXIZA6yzjxwTWyVQTuJyiYMdw5j.FXMa7GcVIuL5CernSqnP6"

# Database
DATABASE_URL="sqlite+aiosqlite:///./farewell.db"

# Admin access — comma-separated list of emails that can log in to the admin portal
ADMIN_EMAILS="rvk.vit@gmail.com,ext-rovin.krishnia@lahitapiola.fi"

# CORS
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# File uploads
UPLOAD_DIR="./data/uploads"
UPLOADS_BASE_URL="http://localhost:8000/uploads"
MAX_UPLOAD_SIZE_MB=50

# Logging
LOG_LEVEL="INFO"                           # DEBUG | INFO | WARNING | ERROR
