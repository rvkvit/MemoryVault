# Internal URL used by Next.js server-side fetches (RSC → FastAPI)
# Never exposed to the browser
BACKEND_URL=http://localhost:8000

# Public URL the browser uses for API calls (same-origin via Next.js proxy)
NEXT_PUBLIC_API_URL=http://localhost:3000

# App metadata
NEXT_PUBLIC_APP_NAME=Farewell

# LinkedIn profile URL — shown in the "Stay Connected" section after a memory is submitted
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/your-profile
